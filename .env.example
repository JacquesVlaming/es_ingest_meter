# Elasticsearch connection
ES_HOST=https://your-cluster.es.io:443
ES_API_KEY=your-base64-encoded-api-key

# Optional basic auth (leave blank if using API key)
ES_USERNAME=
ES_PASSWORD=

# Scheduler settings
TARGET_MB=10
DOC_SIZE_KB=1
BATCH_SIZE=500
INTERVAL_HOURS=24

# Set to any non-empty value to keep test indices after each run (e.g. KEEP_INDEX=1)
KEEP_INDEX=
